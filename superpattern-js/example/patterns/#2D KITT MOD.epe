{
  "name": "#2D KITT MOD",
  "id": "P8g68xGyz3ouYDZh4",
  "sources": {
    "main": "export var tailPct = .6 // length of the tail in 0..1\r\nexport var speed = .05\r\nexport var pct1\r\nexport var pct2\r\n\r\nexport var h\r\nexport var color\r\nexport var fade\r\nexport var fadespeed\r\n\r\nexport function sliderTail (v) {\r\n  tailPct = .6 + v/3;\r\n}\r\n\r\nexport function sliderSpeed (v) {\r\n  speed = v/10;\r\n}\r\n\r\nexport function sliderColor (v) {\r\n  color = v\r\n}\r\n\r\nexport function sliderFade (v) {\r\n  fade = floor(v)\r\n}\r\n\r\nexport function sliderFadespeed (v) {\r\n  fadespeed = 0.1 + v/3\r\n}\r\n\r\nexport function render3D(index,x,y,z) {\r\n  pct1 =  z/2 - time(speed)\r\n  pct2 = -z/2 - time(speed)\r\n  v = max (0,( tailPct - 1 + triangle(pct1) * square(pct1,.5) ) / tailPct )\r\n    + max (0,( tailPct - 1 + triangle(pct2) * square(pct2,.5) ) / tailPct )\r\n  h = color + fade*wave(time(fadespeed))\r\n  hsv(h, 1, v * v * v)\r\n}"
  },
  "preview": ""
}