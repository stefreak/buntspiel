{
  "name": "#PL Leuchtturm Rot",
  "id": "jMiuoKsWsgnFewpas",
  "sources": {
    "main": "var onOff\n\nexport function toggleOnOff(isEnabled){\n  \n  onOff = isEnabled\n}\n\n\n\nexport function beforeRender(delta) {\n  t1 = square(time(.01), 0.5)\n  t2 = wave(time(.5))\n  t3 = wave(time(.05))\n  t4 = (t4 - delta * 0.0005) % 1\n  N = 48\n  AnzahlStreifen = 4\n}\n\nexport function render(index) {\n  index = index % N\n  farbe = 1-(t2)\n  offset = 0 %t3 * 5 \n  squareColor = square((AnzahlStreifen/2* (index + offset) / N), .5)\n  squareWhite = square((AnzahlStreifen/2 * (index + N/AnzahlStreifen + offset) / N), .5)\n  h = squareColor*farbe + squareWhite\n  s = squareColor\n  v = squareColor + 1*squareWhite * !(index % 1) \n  \n  //s = square((2 * index / N), .5) * 1 + 0\n  //v = square((2 * index / N), .5) * 1 +  0.3 * ((index+1) % 2) //+  0.5 * ((index+1*t1) % 2)\n  \n  hsv(h, s, v)\n}\n\n\n\n// You can also project up a dimension. Think of this as mixing in the z value\n// to x and y in order to compose a stack of matrices.\nexport function render3D(index, x, y, z) {\n  \n    farbe = 1\n    \n  //farbe = t4 \n  offset = 0 %t3 * 5 \n  squareColor = square((AnzahlStreifen/2* (index + offset) / N), .5)\n  squareWhite = square((AnzahlStreifen/2 * (index + N/AnzahlStreifen + offset) / N), .5)\n  h = squareColor*farbe + squareWhite\n  s = squareColor\n  v = squareColor + 1*squareWhite * !(index % 2) * 1\n  \n\n\n  \n  //s = square((2 * index / N), .5) * 1 + 0\n  //v = square((2 * index / N), .5) * 1 +  0.3 * ((index+1) % 2) //+  0.5 * ((index+1*t1) % 2)\n  \n  hsv(h, s, v)\n}\n\n"
  },
  "preview": ""
}