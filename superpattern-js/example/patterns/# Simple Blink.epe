{
  "name": "# Simple Blink",
  "id": "AgR8ecL5Reo3wpjRA",
  "sources": {
    "main": "var OneSecond = 0.015\r\n\r\nvar hue = 1\r\nvar saturation = 1\r\nexport function hsvPickerPrimaryColor (h, s, v) {\r\n  hue = h\r\n  saturation = s\r\n  // we ignore value, as we calculate below.\r\n}\r\n\r\nexport var colorInterval = OneSecond\r\nexport function sliderColorInterval (v) {\r\n  colorInterval = (v * 10 * OneSecond);\r\n}\r\n\r\nvar timeInterval = OneSecond\r\nexport function sliderTimeInterval (v) {\r\n  timeInterval = 0.005 + (v * 5 * OneSecond);\r\n}\r\n\r\nexport var pauseAnzahl = 0\r\nexport function sliderpauseAnzahl (v) {\r\n  pauseAnzahl = floor(v * 10);\r\n}\r\n\r\n\r\nexport var blinkAnzahl = 1\r\nexport function sliderblinkAnzahl (v) {\r\n  blinkAnzahl = 1 + floor(v * 9);\r\n}\r\n\r\nexport var w1\r\nexport var sq\r\nexport function beforeRender(delta) {\r\n  w1 = wave(time(timeInterval) - PI2)\r\n  \r\n  var n = pauseAnzahl + blinkAnzahl\r\n  sq = square(time(timeInterval * n), blinkAnzahl / n)\r\n  \r\n  // for color\r\n  w2 = wave(time(colorInterval * n))\r\n}\r\n\r\nexport var value\r\nexport function render(index) {\r\n  value = w1 * sq\r\n  if (colorInterval) {\r\n    hsv(w2, saturation, value)\r\n  } else {\r\n    hsv(hue, saturation, value)\r\n  }\r\n}\r\n \r\n"
  },
  "preview": ""
}