{
  "name": "# Leuchturm (rotate)",
  "id": "ec4aRjeGBeGWutdxi",
  "sources": {
    "main": "var mode\nvar onOff\nvar speedRange = 1/500\nvar speed = speedRange\nvar N = 48\n\nexport function sliderSpeedRange(s){\n  speed = s*s*speedRange\n}\n\nexport function toggleOnOff(isEnabled){\n  \n  onOff = isEnabled\n}\n\nexport function togglemode(isEnabled){\n  \n  mode = isEnabled\n}\n\nexport function beforeRender(delta) {\n  t1 = square(time(.01), 0.5)\n  t2 = wave(time(.5))\n  t3 = wave(time(.1))\n  t4 = (t4 + delta * speed) % 1\n  t_1Hz = time(0.01)\n  \n  AnzahlStreifen = 1\n}\n\nexport function render(index) {\n  index = index % N\n  farbe = 1-(t2* mode)\n  offset = 0 %t3 * 5 \n  squareColor = square((AnzahlStreifen/2* (index + offset) / N), .5)\n  squareWhite = square((AnzahlStreifen/2 * (index + N/AnzahlStreifen + offset) / N), .5)\n  h = squareColor*farbe + squareWhite\n  s = squareColor\n  v = squareColor + 1*squareWhite * !(index % 1) \n  \n  //s = square((2 * index / N), .5) * 1 + 0\n  //v = square((2 * index / N), .5) * 1 +  0.3 * ((index+1) % 2) //+  0.5 * ((index+1*t1) % 2)\n  \n  hsv(h, s, v)\n}\n\nexport var alph = array(N*6)\n\n// You can also project up a dimension. Think of this as mixing in the z value\n// to x and y in order to compose a stack of matrices.\nexport function render3D(index, x, y, z) {\n  n = floor(index / (N))\n  alpha = n/(pixelCount/N) * 2 * PI\n  \n  if (onOff){\n  index_ = index % N\n  if (mode){\n    farbe = t4 + alpha/(2*PI)/6\n  }else{\n    farbe = 1\n  }\n  \n   \n  winkel = n/(pixelCount/N) //zwischen 0 und 1\n  impuls = square(t_1Hz, 0.1)\n  \n  rotator = floor(t_1Hz * 6) \n  if ((rotator == n)){\n    bling = 1\n  } else{\n    bling = 0\n\n  }\n  test = 1 - (abs((rotator - n)/3) - rotator/3 ) / 2\n  bling = 1 - abs((rotator - n)/3)/(2*1)\n  bling = bling //* bling\n  \n \n  //if (index==180) alph = rotator//floor(index / N)\n  alph[floor(index/N)] = test\n  offset = 0 %t3 * 5 \n  squareColor = square((AnzahlStreifen/2* (index_ + offset) / N), .5)\n  squareWhite = square((AnzahlStreifen/2 * (index_ + N/AnzahlStreifen + offset) / N), .5)\n  h = squareColor*farbe + squareWhite\n  s = squareColor\n  v = squareColor*bling + 0*squareWhite * !(index % 2) * 1\n  \n  \n  \n    \n  } else{\n    h = 0\n    s = 0\n    v = 0\n  }\n  \n  //s = square((2 * index / N), .5) * 1 + 0\n  //v = square((2 * index / N), .5) * 1 +  0.3 * ((index+1) % 2) //+  0.5 * ((index+1*t1) % 2)\n  \n  hsv(h, s, v)\n}\n\n"
  },
  "preview": ""
}