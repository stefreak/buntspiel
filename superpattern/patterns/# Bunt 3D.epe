{
  "name": "# Bunt 3D",
  "id": "2FYM9a8CrTCGDcJdk",
  "sources": {
    "main": "export function beforeRender(delta) {\n  t1 = time(0.5)\n  t2 = time(0.05)\n  t3 = time(0.04)// *square(1, 1)\n}\n\nexport function render3D(index,x,y) {\n  //h = t1 + index/pixelCount\n  h = (t1-index/48/40)\n  s = 1 //(wave(t2*4)+1)*0.4\n  v = (wave(t2)+1)//*0.4\n  // The hue output range is -0.5 to 1.5. hsv() will wrap hues outside 0..1.\n  \n // v = (1 + sin(x + t1) + cos(y + t1)) * 1\n  \n  \n  //v = ((1+y)*t1*5)/2\n  v = v*v*v*v\n  \n  hsv(h, s, v,)\n}"
  },
  "preview": ""
}